{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@onemantec/shared/*": ["packages/shared/src/*"],
      "@onemantec/ui/*": ["packages/ui/src/*"],
      "@onemantec/domain-auth/*": ["packages/domain-auth/src/*"],
      "@onemantec/domain-customer/*": ["packages/domain-customer/src/*"],
      "@onemantec/domain-model/*": ["packages/domain-model/src/*"],
      "@onemantec/domain-resource/*": ["packages/domain-resource/src/*"],
      "@onemantec/domain-billing/*": ["packages/domain-billing/src/*"],
      "@onemantec/domain-gateway/*": ["packages/domain-gateway/src/*"]
    }
  }
}
